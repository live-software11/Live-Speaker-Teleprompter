{
  "appId": "com.rspeaker.teleprompter",
  "appName": "R-Speaker Teleprompter",
  "webDir": ".",
  "bundledWebRuntime": false,
  "ios": {
    "preferredContentMode": "mobile"
  },
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#000000",
      "showSpinner": false
    },
    "Keyboard": {
      "resize": "none"
    }
  }
}
