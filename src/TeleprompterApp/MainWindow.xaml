<Window x:Class="TeleprompterApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TeleprompterApp"
        mc:Ignorable="d"
        Title="R-Speaker Teleprompter"
    Width="1260" Height="760" MinWidth="900" MinHeight="500"
    WindowStartupLocation="CenterScreen" WindowState="Maximized"
    Loaded="Window_Loaded" Closing="Window_Closing"
    PreviewKeyDown="Window_PreviewKeyDown" PreviewKeyUp="Window_PreviewKeyUp" PreviewMouseWheel="Window_PreviewMouseWheel"
    AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}" Executed="SaveCommand_Executed" CanExecute="SaveCommand_CanExecute" />
        <CommandBinding Command="{x:Static ApplicationCommands.Open}" Executed="OpenCommand_Executed" />
        <CommandBinding Command="{x:Static ApplicationCommands.New}" Executed="NewCommand_Executed" />
    </Window.CommandBindings>
    <Window.InputBindings>
        <KeyBinding Command="{x:Static ApplicationCommands.Save}" Modifiers="Control" Key="S" />
        <KeyBinding Command="{x:Static ApplicationCommands.Open}" Modifiers="Control" Key="O" />
        <KeyBinding Command="{x:Static ApplicationCommands.New}" Modifiers="Control" Key="N" />
    </Window.InputBindings>

    <Window.Resources>
        <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#070D1C" Offset="0" />
            <GradientStop Color="#101B33" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6" />

        <Style x:Key="TbBtn" TargetType="ButtonBase">
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="Background" Value="#19233A" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="BorderBrush" Value="#233253" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F3B68" />
                                <Setter Property="BorderBrush" Value="#2563EB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TbTgl" TargetType="ToggleButton" BasedOn="{StaticResource TbBtn}">
            <Setter Property="Background" Value="#1C253F" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#1F4FDB" />
                                <Setter Property="BorderBrush" Value="#60A5FA" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E3A8A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MonitorToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource TbTgl}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>
        <Style x:Key="PlayBtn" TargetType="ToggleButton" BasedOn="{StaticResource TbTgl}">
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A2030" Offset="0" />
                        <GradientStop Color="#0F172A" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border CornerRadius="20" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2563EB" Offset="0" />
                                            <GradientStop Color="#1D4ED8" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="BorderBrush" Value="#60A5FA" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="OnAirBtn" TargetType="ToggleButton" BasedOn="{StaticResource TbTgl}">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Background" Value="#1F2937" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border CornerRadius="10" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#DC2626" />
                                <Setter Property="BorderBrush" Value="#EF4444" />
                                <Setter Property="Foreground" Value="#FEE2E2" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#F87171" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- keep old names for code-behind FindResource -->
        <Style x:Key="ToolbarButtonStyle" TargetType="ButtonBase" BasedOn="{StaticResource TbBtn}" />
        <Style x:Key="ToolbarToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource TbTgl}" />
        <Style x:Key="PlayToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource PlayBtn}" />
        <Style x:Key="OnAirToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource OnAirBtn}" />
        <Style x:Key="HeaderSectionBorder" TargetType="Border">
            <Setter Property="Background" Value="#111C33" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="4" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0: TOOLBAR COMPATTA (2 RIGHE) ═══ -->
        <Border Grid.Row="0" Margin="6,4,6,2" Background="#0B1223" Padding="6,4" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Riga 1: File, Formattazione, Velocità, Play, Inizio/Fine, Modifica -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <!-- File -->
                    <Button x:Name="OpenFileButton" Style="{StaticResource TbBtn}" Click="OpenFileButton_Click" ToolTip="Apri (Ctrl+O)">
                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#60A5FA" />
                    </Button>
                    <Button x:Name="NewDocumentButton" Style="{StaticResource TbBtn}" Click="NewDocumentButton_Click" ToolTip="Nuovo (Ctrl+N)">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#60A5FA" />
                    </Button>
                    <Button x:Name="SaveDocumentButton" Style="{StaticResource TbBtn}" Click="SaveDocumentButton_Click" ToolTip="Salva (Ctrl+S)">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#60A5FA" />
                    </Button>
                    <Border Width="1" Background="#1E2A44" Margin="4,3" />

                    <!-- Formattazione -->
                    <ToggleButton Style="{StaticResource TbTgl}" Command="{x:Static EditingCommands.ToggleBold}" CommandTarget="{Binding ElementName=ContentEditor}">
                        <TextBlock Text="B" FontWeight="Bold" FontSize="13" />
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource TbTgl}" Command="{x:Static EditingCommands.ToggleItalic}" CommandTarget="{Binding ElementName=ContentEditor}">
                        <TextBlock Text="I" FontStyle="Italic" FontSize="13" />
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource TbTgl}" Command="{x:Static EditingCommands.ToggleUnderline}" CommandTarget="{Binding ElementName=ContentEditor}">
                        <TextBlock Text="U" TextDecorations="Underline" FontSize="13" />
                    </ToggleButton>
                    <ComboBox x:Name="FontSizeComboBox" Width="56" Margin="4,0" VerticalAlignment="Center" SelectedValuePath="Content" SelectionChanged="FontSizeComboBox_SelectionChanged" ToolTip="Dimensione font">
                        <ComboBoxItem Content="36" /><ComboBoxItem Content="48" /><ComboBoxItem Content="60" />
                        <ComboBoxItem Content="72" /><ComboBoxItem Content="84" /><ComboBoxItem Content="96" /><ComboBoxItem Content="120" />
                    </ComboBox>
                    <Button x:Name="FontButton" Style="{StaticResource TbBtn}" Click="FontButton_Click" ToolTip="Font">
                        <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#60A5FA" />
                    </Button>
                    <Button x:Name="BackgroundButton" Style="{StaticResource TbBtn}" Click="BackgroundButton_Click" ToolTip="Sfondo">
                        <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#60A5FA" />
                    </Button>
                    <Button x:Name="ForegroundButton" Style="{StaticResource TbBtn}" Click="ForegroundButton_Click" ToolTip="Colore testo">
                        <TextBlock Text="&#xE8D3;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#60A5FA" />
                    </Button>
                    <Border Width="1" Background="#1E2A44" Margin="4,3" />

                    <!-- Velocità -->
                    <TextBlock x:Name="SpeedText" Text="0.50" Foreground="White" FontSize="13" FontWeight="SemiBold" Width="38" TextAlignment="Center" VerticalAlignment="Center" />
                    <Slider x:Name="SpeedSlider" Minimum="-80" Maximum="80" SmallChange="0.5" LargeChange="2" IsSnapToTickEnabled="False" Value="0.5" Width="90" VerticalAlignment="Center" ValueChanged="SpeedSlider_ValueChanged" />
                    <Border Width="1" Background="#1E2A44" Margin="4,3" />

                    <!-- Inizio/Fine + Play/Pausa -->
                    <Button x:Name="GoToStartButton" Style="{StaticResource TbBtn}" Click="GoToStartButton_Click" ToolTip="Inizio (Home)">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#60A5FA" />
                    </Button>
                    <ToggleButton x:Name="PlayPauseToggle" Style="{StaticResource PlayBtn}" ToolTip="Avvia / Pausa (Spazio in modalità non-modifica)" Checked="PlayPauseToggle_Checked" Unchecked="PlayPauseToggle_Unchecked">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Fill" Value="#F8FAFC" />
                                        <Setter Property="Data" Value="M2,2 L2,18 L16,10 Z" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                <Setter Property="Data" Value="M2,2 L2,18 L8,18 L8,2 Z M12,2 L12,18 L18,18 L18,2 Z" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <TextBlock FontSize="15" FontWeight="Bold" Foreground="#F8FAFC">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Avvia" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                <Setter Property="Text" Value="Pausa" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ToggleButton>
                    <Button x:Name="GoToEndButton" Style="{StaticResource TbBtn}" Click="GoToEndButton_Click" ToolTip="Fine (End)">
                        <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#60A5FA" />
                    </Button>
                    <Border Width="1" Background="#1E2A44" Margin="4,3" />

                    <!-- Schermi + NDI + Modifica + Opzioni -->
                    <StackPanel x:Name="MonitorTogglePanel" Orientation="Horizontal" />
                    <ToggleButton x:Name="NdiToggle" Style="{StaticResource TbTgl}" Content="NDI" Margin="4,0" Checked="NdiToggle_Checked" Unchecked="NdiToggle_Unchecked" FontSize="12" />
                    <Border Width="1" Background="#1E2A44" Margin="4,3" />
                    <ToggleButton x:Name="OnAirToggle" Style="{StaticResource OnAirBtn}" IsChecked="False" Checked="OnAirToggle_Checked" Unchecked="OnAirToggle_Unchecked" ToolTip="On-Air ON: testo bloccato, schermo esterno=preview. Off: modifica script, relatore vede modifiche in diretta">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,4,0" Foreground="#94A3B8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#94A3B8" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                <Setter Property="Foreground" Value="#FEE2E2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#94A3B8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="OFF" />
                                        <Setter Property="Foreground" Value="#94A3B8" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                <Setter Property="Text" Value="ON AIR" />
                                                <Setter Property="Foreground" Value="#FEE2E2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="MirrorToggle" Style="{StaticResource TbTgl}" ToolTip="Specchio" Checked="MirrorToggle_Checked" Unchecked="MirrorToggle_Unchecked">
                        <TextBlock Text="&#xE7C5;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </ToggleButton>
                    <ToggleButton x:Name="TopMostToggle" Style="{StaticResource TbTgl}" ToolTip="Sempre in primo piano" Checked="TopMostToggle_Checked" Unchecked="TopMostToggle_Unchecked">
                        <TextBlock Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </ToggleButton>
                </StackPanel>

                <!-- Riga 2: Margini L, D, L=D, Dimensione freccia, Freccia -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Margini:" Foreground="#64748B" FontSize="11" VerticalAlignment="Center" Margin="2,0" />
                    <TextBlock Text="L" Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center" Margin="0,0,2,0" ToolTip="Sinistra (dopo freccia)" />
                    <Slider x:Name="LeftMarginSlider" Minimum="0" Maximum="800" Value="40" Width="55" SmallChange="4" LargeChange="20" IsSnapToTickEnabled="False" VerticalAlignment="Center" ValueChanged="LeftMarginSlider_ValueChanged" ToolTip="Margine sinistro (testo dopo freccia)" />
                    <TextBlock x:Name="LeftMarginValueText" Text="40" Foreground="#94A3B8" FontSize="10" Width="28" VerticalAlignment="Center" Margin="2,0,4,0" />
                    <TextBlock Text="D" Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center" Margin="0,0,2,0" ToolTip="Destro" />
                    <Slider x:Name="MarginRightSlider" Minimum="0" Maximum="800" Value="40" Width="55" SmallChange="4" LargeChange="20" IsSnapToTickEnabled="False" VerticalAlignment="Center" ValueChanged="MarginRightSlider_ValueChanged" />
                    <TextBlock x:Name="MarginRightText" Text="40" Foreground="#94A3B8" FontSize="10" Width="28" VerticalAlignment="Center" Margin="2,0,4,0" />
                    <Button x:Name="LinkMarginsButton" Style="{StaticResource TbBtn}" Click="LinkMarginsButton_Click" ToolTip="Imposta L=D (margini sinistro e destro uguali)">
                        <TextBlock Text="L=D" FontSize="11" />
                    </Button>
                    <ToggleButton x:Name="MarginsLinkedToggle" Style="{StaticResource TbTgl}" ToolTip="Margini insieme (attivo) / individuali: modifica un margine = modifica tutti quando attivo" Checked="MarginsLinkedToggle_Changed" Unchecked="MarginsLinkedToggle_Changed">
                        <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                    </ToggleButton>
                    <Border Width="1" Background="#1E2A44" Margin="4,3" />
                    <TextBlock Text="A" Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center" Margin="0,0,2,0" ToolTip="Alto" />
                    <Slider x:Name="MarginTopSlider" Minimum="0" Maximum="800" Value="40" Width="45" SmallChange="4" LargeChange="20" VerticalAlignment="Center" ValueChanged="MarginTopSlider_ValueChanged" />
                    <TextBlock x:Name="MarginTopText" Text="40" Foreground="#94A3B8" FontSize="10" Width="24" VerticalAlignment="Center" Margin="2,0,4,0" />
                    <TextBlock Text="B" Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center" Margin="0,0,2,0" ToolTip="Basso" />
                    <Slider x:Name="MarginBottomSlider" Minimum="0" Maximum="800" Value="40" Width="45" SmallChange="4" LargeChange="20" VerticalAlignment="Center" ValueChanged="MarginBottomSlider_ValueChanged" />
                    <TextBlock x:Name="MarginBottomText" Text="40" Foreground="#94A3B8" FontSize="10" Width="24" VerticalAlignment="Center" Margin="2,0,6,0" />
                    <Border Width="1" Background="#1E2A44" Margin="4,3" />
                    <TextBlock Text="Freccia:" Foreground="#64748B" FontSize="11" VerticalAlignment="Center" Margin="2,0" />
                    <Slider x:Name="ArrowSizeSlider" Minimum="0.5" Maximum="2.0" Value="1.0" Width="80" SmallChange="0.1" LargeChange="0.2" IsSnapToTickEnabled="False" VerticalAlignment="Center" ValueChanged="ArrowSizeSlider_ValueChanged" ToolTip="Dimensione freccia" />
                    <Button x:Name="ArrowStyleButton" Style="{StaticResource TbBtn}" Click="ArrowStyleButton_Click" ToolTip="Freccia: colore e opzioni (trascina per posizione)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xECA7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#EAB308" Margin="0,0,4,0" />
                            <TextBlock Text="Freccia" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Border Width="1" Background="#1E2A44" Margin="4,3" />
                    <TextBlock Text="Preset:" Foreground="#64748B" FontSize="11" VerticalAlignment="Center" Margin="2,0" />
                    <ToggleButton x:Name="PresetSave1" Style="{StaticResource TbTgl}" Click="PresetSave_Click" Tag="1" ToolTip="Salva preset 1" Content="S1" FontSize="11" Padding="6,2" />
                    <Button x:Name="PresetLoad1" Style="{StaticResource TbBtn}" Click="PresetLoad_Click" Tag="1" ToolTip="Carica preset 1" Content="L1" FontSize="11" Padding="6,2" />
                    <ToggleButton x:Name="PresetSave2" Style="{StaticResource TbTgl}" Click="PresetSave_Click" Tag="2" ToolTip="Salva preset 2" Content="S2" FontSize="11" Padding="6,2" />
                    <Button x:Name="PresetLoad2" Style="{StaticResource TbBtn}" Click="PresetLoad_Click" Tag="2" ToolTip="Carica preset 2" Content="L2" FontSize="11" Padding="6,2" />
                    <ToggleButton x:Name="PresetSave3" Style="{StaticResource TbTgl}" Click="PresetSave_Click" Tag="3" ToolTip="Salva preset 3" Content="S3" FontSize="11" Padding="6,2" />
                    <Button x:Name="PresetLoad3" Style="{StaticResource TbBtn}" Click="PresetLoad_Click" Tag="3" ToolTip="Carica preset 3" Content="L3" FontSize="11" Padding="6,2" />
                    <ToggleButton x:Name="PresetSave4" Style="{StaticResource TbTgl}" Click="PresetSave_Click" Tag="4" ToolTip="Salva preset 4" Content="S4" FontSize="11" Padding="6,2" />
                    <Button x:Name="PresetLoad4" Style="{StaticResource TbBtn}" Click="PresetLoad_Click" Tag="4" ToolTip="Carica preset 4" Content="L4" FontSize="11" Padding="6,2" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Popup Freccia: colore -->
        <Popup x:Name="ArrowStylePopup" Placement="Bottom" PlacementTarget="{Binding ElementName=ArrowStyleButton}" StaysOpen="False">
            <Border Background="#1E293B" CornerRadius="8" Padding="12" BorderBrush="#334155" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Freccia guida" Foreground="#93C5FD" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Button x:Name="ArrowColorButton" Style="{StaticResource TbBtn}" Content="Colore freccia" Click="ArrowColorButton_Click" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>
        </Popup>

        <!-- ═══ ROW 1: AREA TELEPROMPT ═══ -->
        <Border Grid.Row="1" x:Name="ContentOuterBorder" Margin="6,2,6,2" Padding="4" CornerRadius="12" Background="#0D1729">
            <Grid>
                <Border x:Name="ContentInnerBorder" CornerRadius="10" Background="#111F36" Padding="4" BorderBrush="#1E2A44" BorderThickness="1">
                    <Grid>
                        <ScrollViewer x:Name="ContentScrollViewer" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden" Background="Transparent" PanningMode="VerticalOnly" PreviewKeyDown="ContentScrollViewer_PreviewKeyDown">
                            <RichTextBox x:Name="ContentEditor"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Hidden"
                                         HorizontalScrollBarVisibility="Disabled"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="White"
                                         FontFamily="Segoe UI"
                                         FontSize="72"
                                         SpellCheck.IsEnabled="False"
                                         CaretBrush="#60A5FA"
                                         SelectionBrush="#3B82F6"
                                         SelectionOpacity="0.25"
                                         RenderOptions.ClearTypeHint="Enabled"
                                         TextOptions.TextFormattingMode="Ideal"
                                         TextOptions.TextRenderingMode="ClearType"
                                         UseLayoutRounding="True">
                                <FlowDocument PagePadding="40" LineHeight="86" TextAlignment="Center" />
                            </RichTextBox>
                        </ScrollViewer>
                        <Canvas x:Name="ArrowCanvas" Background="{x:Null}" SizeChanged="ArrowCanvas_SizeChanged">
                            <Grid x:Name="ArrowContainer" Width="72" Height="72" Canvas.Left="36" Canvas.Top="200" Cursor="Hand" ClipToBounds="False"
                                  MouseLeftButtonDown="ArrowContainer_MouseLeftButtonDown"
                                  MouseMove="ArrowContainer_MouseMove"
                                  MouseLeftButtonUp="ArrowContainer_MouseLeftButtonUp">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="ArrowScaleTransform" ScaleX="1" ScaleY="1" />
                                </Grid.RenderTransform>
                                <Polygon x:Name="ArrowShape"
                                         Points="0,20 34,20 34,6 70,36 34,66 34,52 0,52"
                                         Fill="#FFEAB308" Stroke="#FFFFF08A" StrokeThickness="3" StrokeLineJoin="Round">
                                    <Polygon.Effect>
                                        <DropShadowEffect Color="#99000000" BlurRadius="12" ShadowDepth="0" Opacity="0.6" />
                                    </Polygon.Effect>
                                </Polygon>
                            </Grid>
                        </Canvas>
                        <!-- Margini trascinabili visibili in preview -->
                        <Canvas x:Name="MarginThumbsCanvas" Background="{x:Null}" IsHitTestVisible="True" SizeChanged="MarginThumbsCanvas_SizeChanged"
                                MouseMove="MarginThumbsCanvas_MouseMove" MouseLeftButtonUp="MarginThumbsCanvas_MouseLeftButtonUp">
                            <Border x:Name="LeftMarginThumb" Width="8" Cursor="SizeWE" Background="#4060A5FA" Opacity="0.6" BorderBrush="#60A5FA" BorderThickness="1"
                                    MouseLeftButtonDown="MarginThumb_MouseLeftButtonDown" Tag="Left" ToolTip="Trascina per margine sinistro" />
                            <Border x:Name="RightMarginThumb" Width="8" Cursor="SizeWE" Background="#4060A5FA" Opacity="0.6" BorderBrush="#60A5FA" BorderThickness="1"
                                    MouseLeftButtonDown="MarginThumb_MouseLeftButtonDown" Tag="Right" ToolTip="Trascina per margine destro" />
                            <Border x:Name="TopMarginThumb" Height="8" Cursor="SizeNS" Background="#4060A5FA" Opacity="0.6" BorderBrush="#60A5FA" BorderThickness="1"
                                    MouseLeftButtonDown="MarginThumb_MouseLeftButtonDown" Tag="Top" ToolTip="Trascina per margine alto" />
                            <Border x:Name="BottomMarginThumb" Height="8" Cursor="SizeNS" Background="#4060A5FA" Opacity="0.6" BorderBrush="#60A5FA" BorderThickness="1"
                                    MouseLeftButtonDown="MarginThumb_MouseLeftButtonDown" Tag="Bottom" ToolTip="Trascina per margine basso" />
                        </Canvas>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ ROW 2: STATUSBAR ═══ -->
        <Border Grid.Row="2" Margin="6,0,6,4" Background="#0B1223" CornerRadius="8" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Center" Text="Pronto" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock x:Name="ScrollProgressText" Foreground="#60A5FA" FontSize="12" Text="0%" Margin="0,0,6,0" />
                    <Border Background="#1E293B" CornerRadius="3" Width="80" Height="6">
                        <Border x:Name="ScrollProgressBar" Background="#3B82F6" CornerRadius="3" HorizontalAlignment="Left" Width="0" Height="6" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock x:Name="OnAirTimerText" Foreground="#94A3B8" FontSize="12" Text="00:00" FontFamily="Consolas" MinWidth="48" />
                    <Button x:Name="TimerResetButton" Style="{StaticResource TbBtn}" Click="TimerResetButton_Click" ToolTip="Azzera timer (anche con Home/Inizio)" Padding="6,4" Margin="4,0,0,0">
                        <TextBlock Text="Reset" FontSize="11" />
                    </Button>
                </StackPanel>
                <TextBlock Grid.Column="3" Foreground="#4ADE80" FontWeight="SemiBold" VerticalAlignment="Center" Text="Ctrl+S" FontSize="11" />
            </Grid>
        </Border>
    </Grid>
</Window>
