<Window x:Class="TeleprompterApp.Licensing.LicenseGateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Live Speaker Teleprompter"
        Width="480" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Loaded="Window_Loaded">
    <Window.Resources>
        <LinearGradientBrush x:Key="GateBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#070D1C" Offset="0" />
            <GradientStop Color="#101B33" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="Panel" Color="#111827" />
        <SolidColorBrush x:Key="Accent" Color="#3B82F6" />
        <SolidColorBrush x:Key="Border1" Color="#233253" />
        <SolidColorBrush x:Key="FgMain" Color="#E2E8F0" />
        <SolidColorBrush x:Key="FgMuted" Color="#94A3B8" />
        <SolidColorBrush x:Key="GoldWarn" Color="#F5B84C" />
        <SolidColorBrush x:Key="DangerBg" Color="#3B1010" />
        <SolidColorBrush x:Key="DangerFg" Color="#FCA5A5" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgMain}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#19233A" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{StaticResource FgMain}" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0B1223" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CaretBrush" Value="White" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource GateBg}">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- Title -->
                <RowDefinition Height="Auto" />  <!-- Subtitle -->
                <RowDefinition Height="Auto" />  <!-- Status banner -->
                <RowDefinition Height="Auto" />  <!-- Key input label -->
                <RowDefinition Height="Auto" />  <!-- Key input -->
                <RowDefinition Height="Auto" />  <!-- Primary button -->
                <RowDefinition Height="Auto" />  <!-- Verify button -->
                <RowDefinition Height="Auto" />  <!-- Local error -->
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />  <!-- Fingerprint -->
                <RowDefinition Height="Auto" />  <!-- Hint uninstall -->
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText" Grid.Row="0"
                       Text="ATTIVAZIONE LICENZA"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource Accent}" />

            <TextBlock x:Name="SubtitleText" Grid.Row="1"
                       Margin="0,4,0,18"
                       Text="Inserisci la chiave ricevuta al momento dell'acquisto."
                       FontSize="12"
                       Foreground="{StaticResource FgMuted}"
                       TextWrapping="Wrap" />

            <Border x:Name="StatusBanner" Grid.Row="2"
                    Visibility="Collapsed"
                    Background="#16223A"
                    BorderBrush="{StaticResource Border1}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,10"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock x:Name="StatusBannerTitle"
                               FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource GoldWarn}" />
                    <TextBlock x:Name="StatusBannerBody"
                               Margin="0,4,0,0"
                               FontSize="11"
                               Foreground="{StaticResource FgMuted}"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="StatusBannerHint"
                               Margin="0,6,0,0"
                               FontSize="10"
                               Foreground="{StaticResource FgMuted}"
                               Opacity="0.8"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="KeyLabel" Grid.Row="3"
                       Margin="0,0,0,6"
                       Text="Chiave licenza"
                       FontSize="11"
                       Foreground="{StaticResource FgMuted}" />

            <TextBox x:Name="KeyInput" Grid.Row="4"
                     MaxLength="24"
                     ToolTip="LIVE-XXXX-XXXX-XXXX-XXXX"
                     Text="" />

            <Button x:Name="PrimaryButton" Grid.Row="5"
                    Margin="0,14,0,0"
                    Style="{StaticResource PrimaryBtn}"
                    Content="ATTIVA"
                    Click="OnPrimaryClick" />

            <Button x:Name="VerifyButton" Grid.Row="6"
                    Margin="0,10,0,0"
                    Visibility="Collapsed"
                    Style="{StaticResource SecondaryBtn}"
                    Content="Verifica ora"
                    Click="OnVerifyClick" />

            <TextBlock x:Name="LocalError" Grid.Row="7"
                       Margin="0,10,0,0"
                       Visibility="Collapsed"
                       FontSize="11"
                       Foreground="{StaticResource DangerFg}"
                       TextWrapping="Wrap" />

            <StackPanel x:Name="FingerprintPanel" Grid.Row="9"
                        Margin="0,16,0,0">
                <Border Height="1" Background="{StaticResource Border1}" Margin="0,0,0,10" />
                <TextBlock x:Name="FingerprintLabel"
                           Text="ID computer (per supporto)"
                           FontSize="10"
                           Foreground="{StaticResource FgMuted}" />
                <TextBlock x:Name="FingerprintText"
                           Margin="0,4,0,0"
                           FontFamily="Consolas"
                           FontSize="10"
                           Foreground="{StaticResource FgMuted}"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis" />
                <Button x:Name="CopyFpButton"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource Accent}"
                        FontSize="10"
                        Cursor="Hand"
                        Padding="0"
                        Content="Copia"
                        Click="OnCopyFingerprint" />
            </StackPanel>

            <TextBlock x:Name="UninstallHint" Grid.Row="10"
                       Margin="0,12,0,0"
                       FontSize="9"
                       Opacity="0.6"
                       Foreground="{StaticResource FgMuted}"
                       TextWrapping="Wrap"
                       Text="La disinstallazione rilascia automaticamente la licenza su questo PC." />
        </Grid>
    </Border>
</Window>
