<Window x:Class="TeleprompterApp.PresenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Presenter"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="#0A101F"
        Topmost="True"
        SizeToContent="Manual">
    <Grid>
        <Border Margin="0"
                Padding="0"
                CornerRadius="28"
                Background="#0D1729">
            <Grid>
                <Border x:Name="PresenterInnerBorder"
                        CornerRadius="24"
                        Background="#111F36"
                        Padding="0"
                        BorderBrush="#1E2A44"
                        BorderThickness="1">
                    <Grid>
                        <ScrollViewer x:Name="PresenterScrollViewer"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Hidden"
                                      Background="Transparent"
                                      PanningMode="VerticalOnly">
                            <RichTextBox x:Name="PresenterContent"
                                         IsReadOnly="True"
                                         VerticalScrollBarVisibility="Hidden"
                                         HorizontalScrollBarVisibility="Disabled"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="White"
                                         FontFamily="Segoe UI"
                                         FontSize="72"
                                         Focusable="False"
                                         IsReadOnlyCaretVisible="False">
                                <FlowDocument PagePadding="96" LineHeight="86" TextAlignment="Center" />
                            </RichTextBox>
                        </ScrollViewer>

                        <Canvas x:Name="PresenterArrowCanvas"
                                Background="{x:Null}"
                                IsHitTestVisible="False">
                            <Grid x:Name="PresenterArrowContainer"
                                  Width="72"
                                  Height="72">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="PresenterArrowScaleTransform" ScaleX="1" ScaleY="1" />
                                </Grid.RenderTransform>
                                <Polygon x:Name="PresenterArrowShape"
                                         Points="0,20 34,20 34,6 72,36 34,66 34,52 0,52"
                                         Fill="#FFEAB308"
                                         Stroke="#FFFFF08A"
                                         StrokeThickness="3"
                                         StrokeLineJoin="Round">
                                    <Polygon.Effect>
                                        <DropShadowEffect Color="#99000000" BlurRadius="12" ShadowDepth="0" Opacity="0.6" />
                                    </Polygon.Effect>
                                </Polygon>
                            </Grid>
                        </Canvas>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
