release/*.exe
release/*.zip
release/*.msi
release/*.md
release/~*

# Environment
.env
.env.local

# Logs
*.log

# Editor & OS
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db
*.sw?

# User preferences (generated at runtime)
preferences.json

# Build temp
git-status.txt
